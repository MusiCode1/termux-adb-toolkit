# adbtool configuration
# Copy to config.env and fill in your values.
# config.env is gitignored — safe to store personal values.

# ADB stable TCP port (used by adbtool fix-port and start)
ADB_PORT=5588

# Cloudflare tunnel name (from: cloudflared tunnel create <name>)
# Leave empty to skip cloudflared setup.
CF_TUNNEL_NAME=

# Public hostname for SSH access (e.g. myphone.example.com)
# Leave empty to skip DNS/tunnel setup.
CF_HOSTNAME=
