#!/data/data/com.termux/files/usr/bin/sh
# tunnel — start/stop/status Cloudflare tunnel
# Usage: tunnel [up|down|status]

ACTION="${1:-status}"
SVC="${SVDIR:-/data/data/com.termux/files/usr/var/service}/cloudflared"

case "$ACTION" in
  up)
    sv up "$SVC"
    sleep 1
    sv status "$SVC"
    ;;
  down)
    sv down "$SVC"
    sv status "$SVC"
    ;;
  status)
    sv status "$SVC"
    ;;
  *)
    echo "Usage: tunnel [up|down|status]"
    exit 1
    ;;
esac
